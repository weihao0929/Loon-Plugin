[Rewrite]
# 拦截 VIP 状态接口
^https:\/\/api\.qufaquan\.cn\/zwyd\/grant\/cancel\/upgrade script-response-body WDD_Unlock.js
^https:\/\/api\.qufaquan\.cn\/zwyd\/user\/member script-response-body WDD_Unlock.js

[Script]
# 指定脚本路径
WDD_Unlock.js = type=http-response,pattern=^https:\/\/api\.qufaquan\.cn\/zwyd\/(grant\/cancel\/upgrade|user\/member),requires-body=1,max-size=0,timeout=10,script-path=WDD_Unlock.js
